# Django
SECRET_KEY=replace_with_a_secure_secret_key
DEBUG=True

# Database
DB_NAME=book_db
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# JWT lifetimes in days
JWT_ACCESS_TOKEN_LIFETIME=5
JWT_REFRESH_TOKEN_LIFETIME=1

# Optional OpenAI integration
# Leave OPENAI_API_KEY empty to use the local fallback summary/audio logic.
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-5.4-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_INSTRUCTIONS=Speak clearly, warmly, and naturally like an attentive audiobook narrator.
